rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Authenticated users can read any file
    match /{allPaths=**} {
      allow read: if request.auth != null;
    }

    // Job-related uploads
    match /jobs/{jobId}/{allPaths=**} {
      allow write: if request.auth != null;
    }

    // Estimate-related uploads
    match /estimates/{estimateId}/{allPaths=**} {
      allow write: if request.auth != null;
    }

    // Proposal files
    match /proposals/{proposalId}/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
